# 카카오 로그인 (Kakao Developers > 내 애플리케이션 > 앱 키)
# JavaScript 키 - 클라이언트 로그인용 (NEXT_PUBLIC_ 필수)
NEXT_PUBLIC_KAKAO_JS_KEY=
# REST API 키 (플랫폼 키) - 서버/토큰 교환용
KAKAO_REST_API_KEY=
# 앱 Admin 키 - 서버 전용 (절대 클라이언트에 노출 금지)
KAKAO_ADMIN_KEY=
# 리다이렉트 URI (선택, 기본: {origin}/auth/kakao/callback)
# NEXT_PUBLIC_KAKAO_REDIRECT_URI=

# ⚠️ Kakao Developers에 리다이렉트 URI 등록 필요:
# - http://localhost:3000/auth/kakao/callback
# - https://kuspba.vercel.app/auth/kakao/callback

# 데이터베이스 (추후 Prisma/DB 연동 시)
# DATABASE_URL=

# 무통장 입금 안내용 계좌 정보 (관리자 설정 또는 환경변수)
# BANK_NAME=
# BANK_ACCOUNT=
# DEPOSIT_HOLDER=
